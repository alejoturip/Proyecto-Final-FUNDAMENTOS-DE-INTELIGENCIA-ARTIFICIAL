# Copia este archivo como .env y ajusta la URL.
# Vite solo expone al navegador las variables que empiezan con VITE_ (es obligatorio).

# En local:
VITE_API_URL=http://localhost:8000

# En producción (Netlify): compila con esta variable apuntando a tu backend de Render.
# VITE_API_URL=https://tu-backend.onrender.com
